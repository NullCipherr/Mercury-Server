  "features": {
    "title": "Feito para engenharia de sistema, não para esconder complexidade",
    "description": "Arquitetura orientada a previsibilidade operacional: menos mágica, mais controle de I/O, limites explícitos e fluxo de request transparente para debug e evolução.",
    "cards": [
      {
        "title": "Parser HTTP manual",
        "description": "Sem framework web. Parsing direto com limites de header/body configuráveis e foco em robustez."
      },
      {
        "title": "Pool thread-safe",
        "description": "Fila concorrente desacopla accept do processamento e reduz churn de threads."
      },
      {
        "title": "Métricas embutidas",
        "description": "Endpoint /metrics com contadores de requests, erros e latência média."
      },
      {
        "title": "Hardening básico",
        "description": "Timeouts por conexão, validação de payload e proteção contra path traversal no static server."
      },
      {
        "title": "Operação prática",
        "description": "Execução via Zig, Makefile e Docker Compose para ambiente local ou pipeline CI/CD."
      },
      {
        "title": "Base para crescer",
        "description": "Código modular em Zig para evoluir keep-alive, streaming de arquivos e observabilidade avançada."
      }
    ]
  },
